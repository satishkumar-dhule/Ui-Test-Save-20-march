modules = ["nodejs-20", "web", "python-3.12"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[[artifacts]]
id = "artifacts/devprep"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "artifacts/devprep: web"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5173 pnpm --filter @workspace/devprep run dev"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/devprep"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/devprep: web"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["glib", "nss", "nspr", "atk", "cups", "dbus", "libdrm", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "libgbm", "libxkbcommon", "pango", "cairo", "alsa-lib", "gh", "chromium", "chromium-xorg-conf", "firefox", "firefox-esr"]

[[ports]]
localPort = 3001
externalPort = 6000

[[ports]]
localPort = 4096
externalPort = 9000
exposeLocalhost = true

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3001

[[ports]]
localPort = 5175
externalPort = 3000

[[ports]]
localPort = 5176

[[ports]]
localPort = 5177
externalPort = 8000

[[ports]]
localPort = 8788
externalPort = 8099
exposeLocalhost = true

[[ports]]
localPort = 9229
externalPort = 5173
exposeLocalhost = true

[[ports]]
localPort = 9999
externalPort = 5000
