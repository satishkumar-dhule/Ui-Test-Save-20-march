modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "artifacts/devprep: web"
mode = "sequential"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/devprep"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 pnpm --filter @workspace/devprep run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/devprep: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/devprep: api"

[[workflows.workflow]]
name = "artifacts/devprep: api"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "API_PORT=3001 DB_PATH=/home/runner/workspace/data/devprep.db /home/runner/workspace/artifacts/devprep/node_modules/.bin/tsx /home/runner/workspace/artifacts/devprep/server/src/index.ts"
waitForPort = 3001

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
packages = ["gh", "docker", "containerd", "tmux", "vimHugeX"]

[[ports]]
localPort = 3000
externalPort = 8000

[[ports]]
localPort = 4096
externalPort = 9000
exposeLocalhost = true

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 8099

[[ports]]
localPort = 9999
externalPort = 6800
