{
  "name": "devprep-content-generator",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Generates DevPrep study content via opencode-ai and stores it in SQLite",
  "scripts": {
    "generate": "node generate-content.mjs",
    "generate:question": "CONTENT_TYPE=question node generate-content.mjs",
    "generate:flashcard": "CONTENT_TYPE=flashcard node generate-content.mjs",
    "generate:coding": "CONTENT_TYPE=coding node generate-content.mjs",
    "generate:exam": "CONTENT_TYPE=exam node generate-content.mjs",
    "generate:voice": "CONTENT_TYPE=voice node generate-content.mjs",
    "test": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "opencode-ai": "^1.2.27",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "vitest": "^4.1.0"
  }
}
