{
  "name": "@workspace/devprep",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "preview:pwa": "VITE_API_URL=http://localhost:4000 pnpm run serve",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --coverage.reporter=text,lcov",
    "test:integration": "vitest run src/__tests__/integration",
    "mutation": "stryker run",
    "pwa:generate-icons": "pwa-assets-generator icon.svg --preset minimal-192-512"
  },
