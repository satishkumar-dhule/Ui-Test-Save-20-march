{
  "$schema": "https://stryker-mutator.io/schemas/stryker-conf.schema.json",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "json", "dashboard"],
  "htmlReporter": {
    "fileManager": {
      "useConsolidatedReport": true
    }
  },
  "jsonReporter": {
    "addJsonResultsFile": true,
    "filename": "reports/mutation/mutation.json"
  },
  "vitest": {
    "configFile": "vitest.config.ts",
    "enableFindRelatedTests": true
  },
  "mutate": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.d.ts",
    "!src/**/__tests__/**",
    "!src/main.tsx"
  ],
  "mutators": [
    {
      "name": "block-mutator",
      "excludedMutations": []
    }
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "coverage": {
    "perTest": true
  },
  "ignorePatterns": ["node_modules", "dist", "build", "coverage", "tests"],
  "tempDirName": ".stryker-tmp"
}
