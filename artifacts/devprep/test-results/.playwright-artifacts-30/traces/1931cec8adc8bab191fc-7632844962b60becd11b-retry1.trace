tive;\n  padding-top: env(safe-area-inset-top);\n  padding-bottom: env(safe-area-inset-bottom);\n  padding-left: env(safe-area-inset-left);\n  padding-right: env(safe-area-inset-right);\n}\n.app-root::before {\n  content: '';\n  position: fixed;\n  inset: 0;\n  background-image: radial-gradient(circle, rgba(48, 54, 61, 0.4) 1px, transparent 1px);\n  background-size: 24px 24px;\n  pointer-events: none;\n  z-index: 0;\n  opacity: 0.5;\n}\n.app-main {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  min-width: 0;\n  overflow: hidden;\n  position: relative;\n  z-index: 1;\n}\n.sidebar {\n  width: var(--dp-sidebar-width);\n  flex-shrink: 0;\n  display: flex;\n  flex-direction: column;\n  background: var(--dp-glass-0);\n  backdrop-filter: blur(20px) saturate(1.5);\n  -webkit-backdrop-filter: blur(20px) saturate(1.5);\n  border-right: 1px solid var(--dp-border-0);\n  overflow: hidden;\n  position: relative;\n  z-index: 10;\n  transition: transform var(--dp-dur-base) var(--dp-ease);\n}\n@media (max-width: 768px) {\n  .sidebar {\n    position: fixed;\n    inset-y: 0;\n    left: 0;\n    z-index: 50;\n    transform: translateX(-100%);\n    box-shadow: 4px 0 40px rgba(0, 0, 0, 0.5);\n  }\n  .sidebar--mobile-open {\n    transform: translateX(0);\n  }\n}\n.sidebar-logo {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 16px 16px 12px;\n  border-bottom: 1px solid var(--dp-border-1);\n  flex-shrink: 0;\n}\n.sidebar-logo-icon {\n  width: 32px;\n  height: 32px;\n  border-radius: var(--dp-r-md);\n  background: linear-gradient(135deg, var(--dp-blue), #6e40c9);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #fff;\n  flex-shrink: 0;\n  box-shadow: 0 0 16px var(--dp-blue-glow);\n}\n.sidebar-logo-title {\n  font-size: 14px;\n  font-weight: 700;\n  letter-spacing: -0.3px;\n  color: var(--dp-text-0);\n}\n.sidebar-logo-sub {\n  font-size: 11px;\n  color: var(--dp-text-2);\n}\n.sidebar-search {\n  position: relative;\n  margin: 10px 12px 6px;\n  flex-shrink: 0;\n}\n.sidebar-search-icon {\n  position: absolute;\n  left: 10px;\n  top: 50%;\n  transform: translateY(-50%);\n  color: var(--dp-text-3);\n  pointer-events: none;\n}\n.sidebar-search-input {\n  width: 100%;\n  height: 32px;\n  background: var(--dp-bg-2);\n  border: 1px solid var(--dp-border-0);\n  border-radius: var(--dp-r-sm);\n  padding: 0 10px 0 30px;\n  font-size: 12px;\n  color: var(--dp-text-1);\n  outline: none;\n  transition: border-color var(--dp-dur-fast), box-shadow var(--dp-dur-fast);\n  box-sizing: border-box;\n}\n.sidebar-search-input::placeholder {\n  color: var(--dp-text-3);\n}\n.sidebar-search-input:focus {\n  border-color: var(--dp-blue);\n  box-shadow: 0 0 0 3px var(--dp-blue-muted);\n}\n.sidebar-section {\n  flex-shrink: 0;\n  padding: 4px 0;\n}\n.sidebar-section-header {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  padding: 8px 16px 4px;\n  font-size: 10px;\n  font-weight: 600;\n  letter-spacing: 0.8px;\n  text-transform: uppercase;\n  color: var(--dp-text-3);\n}\n.sidebar-section-action {\n  margin-left: auto;\n  color: var(--dp-text-3);\n  background: none;\n  border: none;\n  cursor: pointer;\n  padding: 2px;\n  border-radius: 4px;\n  display: flex;\n  align-items: center;\n  transition: color var(--dp-dur-fast), background var(--dp-dur-fast);\n}\n.sidebar-section-action:hover {\n  color: var(--dp-text-1);\n  background: var(--dp-bg-3);\n}\n.sidebar-channels {\n  overflow-y: auto;\n  max-height: 40vh;\n  padding: 2px 8px;\n  scrollbar-width: thin;\n  scrollbar-color: var(--dp-border-0) transparent;\n}\n.sidebar-channel {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  width: 100%;\n  padding: 8px;\n  border-radius: var(--dp-r-sm);\n  background: none;\n  border: none;\n  cursor: pointer;\n  color: var(--dp-text-1);\n  font-size: 13px;\n  text-align: left;\n  transition: background var(--dp-dur-fast), color var(--dp-dur-fast);\n  position: relative;\n  min-height: 44px;\n  box-sizing: border-box;\n}\n.sidebar-channel:hover {\n  background: var(--dp-bg-3);\n  color: var(--dp-text-0);\n}\n.sidebar-channel--active {\n  background: var(--dp-blue-muted);\n  color: var(--dp-text-0);\n}\n.sidebar-channel--active::before {\n  content: '';\n  position: absolute;\n  left: 0;\n  top: 6px;\n  bottom: 6px;\n  width: 2px;\n  background: var(--channel-color, var(--dp-blue));\n  border-radius: 0 2px 2px 0;\n}\n.sidebar-channel-emoji {\n  font-size: 15px;\n  flex-shrink: 0;\n  width: 20px;\n  text-align: center;\n}\n.sidebar-channel-name {\n  flex: 1;\n  font-size: 13px;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n.sidebar-channel-cert {\n  font-size: 9px;\n  font-weight: 600;\n  padding: 1px 5px;\n  border-radius: var(--dp-r-full);\n  background: rgba(255, 153, 0, 0.12);\n  color: #ff9900;\n  border: 1px solid rgba(255, 153, 0, 0.2);\n  flex-shrink: 0;\n}\n.sidebar-channel-arrow {\n  color: var(--dp-text-2);\n  flex-shrink: 0;\n  opacity: 0.7;\n}\n.sidebar-show-more {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  width: 100%;\n  padding: 5px 8px;\n  color: var(--dp-text-2);\n  font-size: 11px;\n  background: none;\n  border: none;\n  cursor: pointer;\n  border-radius: var(--dp-r-sm);\n  transition: color var(--dp-dur-fast), background var(--dp-dur-fast);\n}\n.sidebar-show-more:hover {\n  color: var(--dp-blue);\n  background: var(--dp-blue-muted);\n}\n.sidebar-empty {\n  padding: 8px;\n  color: var(--dp-text-3);\n  font-size: 12px;\n  text-align: center;\n}\n.sidebar-browse-btn {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  width: calc(100% - 16px);\n  margin: 6px 8px 2px;\n  padding: 7px 10px;\n  background: none;\n  border: 1px dashed var(--dp-border-0);\n  border-radius: var(--dp-r-sm);\n  color: var(--dp-text-2);\n  font-size: 12px;\n  cursor: pointer;\n  transition: all var(--dp-dur-fast);\n}\n.sidebar-browse-btn:hover {\n  border-color: var(--dp-blue);\n  color: var(--dp-blue);\n  background: var(--dp-blue-muted);\n}\n.sidebar-browse-btn svg:last-child {\n  margin-left: auto;\n}\n.sidebar-divider {\n  height: 1px;\n  background: var(--dp-border-1);\n  margin: 8px 16px;\n  flex-shrink: 0;\n}\n.sidebar-sections {\n  padding: 2px 8px;\n}\n.sidebar-sec {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  width: 100%;\n  padding: 8px;\n  border-radius: var(--dp-r-sm);\n  background: none;\n  border: none;\n  cursor: pointer;\n  color: var(--dp-text-1);\n  font-size: 13px;\n  text-align: left;\n  transition: background var(--dp-dur-fast), color var(--dp-dur-fast);\n  min-height: 44px;\n  box-sizing: border-box;\n}\n.sidebar-sec:hover {\n  background: var(--dp-bg-3);\n  color: var(--dp-text-0);\n}\n.sidebar-sec--active {\n  background: var(--sec-color, var(--dp-blue));\n  color: #fff;\n  background: var(--sec-color, var(--dp-blue));\n  @supports (color: color-mix(in lab, red, red)) {\n    background: color-mix(in srgb, var(--sec-color, var(--dp-blue)) 15%, transparent);\n  }\n  color: var(--dp-text-0);\n}\n.sidebar-sec--active .sidebar-sec-icon {\n  filter: drop-shadow(0 0 6px var(--sec-color, var(--dp-blue)));\n}\n.sidebar-sec-icon {\n  display: flex;\n  align-items: center;\n  flex-shrink: 0;\n}\n.sidebar-sec-label {\n  flex: 1;\n  font-weight: 500;\n}\n.sidebar-sec-count {\n  font-size: 11px;\n  font-weight: 600;\n  padding: 1px 6px;\n  border-radius: var(--dp-r-full);\n  background: var(--dp-bg-3);\n  color: var(--dp-text-2);\n  min-width: 22px;\n  text-align: center;\n}\n.sidebar-sec--active .sidebar-sec-count {\n  background: rgba(255, 255, 255, 0.15);\n  color: var(--dp-text-0);\n}\n.sidebar-footer {\n  margin-top: auto;\n  padding: 12px;\n  border-top: 1px solid var(--dp-border-1);\n  flex-shrink: 0;\n}\n.sidebar-footer-btn {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  width: 100%;\n  padding: 8px 10px;\n  background: var(--dp-blue-muted);\n  border: 1px solid rgba(56, 139, 253, 0.25);\n  border-radius: var(--dp-r-sm);\n  color: var(--dp-blue);\n  font-size: 13px;\n  font-weight: 500;\n  cursor: pointer;\n  transition: all var(--dp-dur-fast);\n}\n.sidebar-footer-btn:hover {\n  background: rgba(56, 139, 253, 0.25);\n  box-shadow: 0 0 12px var(--dp-blue-glow);\n}\n.topbar {\n  height: var(--dp-topbar-height);\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 0 16px;\n  background: var(--dp-glass-0);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border-bottom: 1px solid var(--dp-border-0);\n  flex-shrink: 0;\n  position: relative;\n  z-index: 5;\n}\n.topbar-mobile-menu {\n  background: none;\n  border: none;\n  color: var(--dp-text-1);\n  cursor: pointer;\n  padding: 6px;\n  border-radius: var(--dp-r-sm);\n  display: flex;\n  align-items: center;\n  transition: color var(--dp-dur-fast), background var(--dp-dur-fast);\n}\n.topbar-mobile-menu:hover {\n  color: var(--dp-text-0);\n  background: var(--dp-bg-3);\n}\n.topbar-channel {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  flex-shrink: 0;\n}\n.topbar-channel-emoji {\n  font-size: 18px;\n}\n.topbar-channel-name {\n  font-size: 15px;\n  font-weight: 600;\n  color: var(--dp-text-0);\n}\n.topbar-breadcrumb {\n  display: flex;\n  align-items: center;\n  flex-shrink: 0;\n}\n.topbar-breadcrumb-list {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  list-style: none;\n  margin: 0;\n  padding: 0;\n}\n.topbar-breadcrumb-item {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n.topbar-breadcrumb-home {\n  font-size: 14px;\n  font-weight: 600;\n  color: var(--dp-text-0);\n}\n.topbar-breadcrumb-channel {\n  font-size: 14px;\n  font-weight: 500;\n  color: var(--dp-text-1);\n}\n.topbar-breadcrumb-section {\n  font-size: 14px;\n  font-weight: 600;\n  color: var(--dp-blue);\n}\n.topbar-breadcrumb-separator {\n  color: var(--dp-text-3);\n  display: flex;\n  align-items: center;\n}\n@media (max-width: 640px) {\n  .topbar-breadcrumb {\n    display: none;\n  }\n  .topbar-channel {\n    display: flex;\n  }\n}\n.topbar-channel-cert {\n  font-size: 10px;\n  font-weight: 600;\n  padding: 2px 6px;\n  border-radius: var(--dp-r-full);\n  background: rgba(255, 153, 0, 0.12);\n  color: #ff9900;\n  border: 1px solid rgba(255, 153, 0, 0.25);\n}\n.topbar-search {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 6px 12px;\n  background: var(--dp-bg-2);\n  border: 1px solid var(--dp-border-0);\n  border-radius: var(--dp-r-sm);\n  color: var(--dp-text-2);\n  font-size: 13px;\n  cursor: pointer;\n  min-width: 200px;\n  max-width: 320px;\n  width: 100%;\n  transition: border-color var(--dp-dur-fast), box-shadow var(--dp-dur-fast);\n}\n.topbar-search:hover {\n  border-color: var(--dp-border-0);\n  background: var(--dp-bg-3);\n}\n.topbar-search:focus {\n  border-color: var(--dp-blue);\n  box-shadow: 0 0 0 3px var(--dp-blue-muted);\n  outline: none;\n}\n.topbar-search-label {\n  flex: 1;\n  text-align: left;\n}\n.topbar-search-kbd {\n  padding: 1px 6px;\n  font-size: 10px;\n  background: var(--dp-bg-3);\n  border: 1px solid var(--dp-border-0);\n  border-radius: 4px;\n  color: var(--dp-text-3);\n  font-family: inherit;\n}\n.topbar-icon-btn {\n  width: 44px;\n  height: 44px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: none;\n  border: 1px solid var(--dp-border-0);\n  border-radius: var(--dp-r-sm);\n  color: var(--dp-text-1);\n  cursor: pointer;\n  flex-shrink: 0;\n  transition: all var(--dp-dur-fast);\n}\n.topbar-icon-btn:hover {\n  color: var(--dp-text-0);\n  background: var(--dp-bg-3);\n  border-color: var(--dp-border-0);\n}\n.study-main {\n  flex: 1;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n  position: relative;\n}\n.study-loading {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 12px;\n  color: var(--dp-text-2);\n  font-size: 14px;\n}\n.channel-browser-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(1, 4, 9, 0.8);\n  backdrop-filter: blur(8px);\n  -webkit-backdrop-filter: blur(8px);\n  z-index: 100;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 20px;\n  animation: fadeIn var(--dp-dur-fast) var(--dp-ease);\n}\n.channel-browser {\n  background: var(--dp-glass-0);\n  border: 1px solid var(--dp-border-0);\n  border-radius: var(--dp-r-xl);\n  width: 100%;\n  max-width: 900px;\n  max-height: 85vh;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.05);\n  animation: slideUp var(--dp-dur-slow) var(--dp-ease);\n}\n@keyframes slideUp {\n  from {\n    opacity: 0;\n    transform: translateY(20px) scale(0.97);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0) scale(1);\n  }\n}\n@keyframes fadeIn {\n  from {\n    opacity: 0;\n  }\n  to {\n    opacity: 1;\n  }\n}\n.channel-browser-header {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  padding: 20px 24px 16px;\n  border-bottom: 1px solid var(--dp-border-1);\n  flex-shrink: 0;\n}\n.channel-browser-title {\n  font-size: 18px;\n  font-weight: 700;\n  color: var(--dp-text-0);\n  margin: 0;\n}\n.channel-browser-sub {\n  font-size: 13px;\n  color: var(--dp-text-2);\n  margin: 2px 0 0;\n}\n.channel-browser-close {\n  width: 44px;\n  height: 44px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--dp-bg-3);\n  border: 1px solid var(--dp-border-0);\n  border-radius: var(--dp-r-sm);\n  color: var(--dp-text-1);\n  cursor: pointer;\n  transition: all var(--dp-dur-fast);\n}\n.channel-browser-close:hover {\n  color: var(--dp-red);\n  border-color: var(--dp-red);\n}\n.channel-browser-search-wrap {\n  position: relative;\n  padding: 16px 24px 12px;\n  flex-shrink: 0;\n}\n.channel-browser-search-icon {\n  position: absolute;\n  left: 38px;\n  top: 50%;\n  transform: translateY(-50%);\n  color: var(--dp-text-3);\n}\n.channel-browser-search {\n  width: 100%;\n  height: 42px;\n  background: var(--dp-bg-2);\n  border: 1px solid var(--dp-border-0);\n  border-radius: var(--dp-r-md);\n  padding: 0 40px 0 44px;\n  font-size: 14px;\n  color: var(--dp-text-0);\n  outline: none;\n  box-sizing: border-box;\n  transition: border-color var(--dp-dur-fast), box-shadow var(--dp-dur-fast);\n}\n.channel-browser-search::placeholder {\n  color: var(--dp-text-3);\n}\n.channel-browser-search:focus {\n  border-color: var(--dp-blue);\n  box-shadow: 0 0 0 3px var(--dp-blue-muted);\n}\n.channel-browser-clear {\n  position: absolute;\n  right: 38px;\n  top: 50%;\n  transform: translateY(-50%);\n  background: var(--dp-bg-3);\n  border: none;\n  color: var(--dp-text-2);\n  cursor: pointer;\n  padding: 4px;\n  border-radius: 4px;\n  display: flex;\n  transition: color var(--dp-dur-fast);\n}\n.channel-browser-clear:hover {\n  color: var(--dp-text-0);\n}\n.channel-browser-cats {\n  display: flex;\n  gap: 6px;\n  padding: 0 24px 12px;\n  overflow-x: auto;\n  flex-shrink: 0;\n  scrollbar-width: none;\n}\n.channel-browser-cats::-webkit-scrollbar {\n  display: none;\n}\n.channel-cat-pill {\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  padding: 4px 12px;\n  border-radius: var(--dp-r-full);\n  background: var(--dp-bg-2);\n  border: 1px solid var(--dp-border-0);\n  color: var(--dp-text-2);\n  font-size: 12px;\n  font-weight: 500;\n  cursor: pointer;\n  white-space: nowrap;\n  transition: all var(--dp-dur-fast);\n  flex-shrink: 0;\n}\n.channel-cat-pill:hover {\n  color: var(--dp-text-0);\n  border-color: var(--dp-border-0);\n  background: var(--dp-bg-3);\n}\n.channel-cat-pill--active {\n  background: var(--dp-blue-muted);\n  border-color: rgba(56, 139, 253, 0.4);\n  color: var(--dp-blue);\n}\n.channel-cat-pill-count {\n  padding: 0 5px;\n  background: var(--dp-bg-3);\n  border-radius: var(--dp-r-full);\n  font-size: 10px;\n  color: var(--dp-text-3);\n}\n.channel-cat-pill--active .channel-cat-pill-count {\n  background: rgba(56, 139,