stemFont, 'Segoe UI', system-ui, sans-serif;\n      }\n      .app-root {\n        display: flex;\n        height: 100dvh;\n        height: 100svh;\n        width: 100vw;\n        overflow: hidden;\n        background: var(--dp-bg-0);\n        color: var(--dp-text-0);\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n        position: relative;\n        padding-top: env(safe-area-inset-top);\n        padding-bottom: env(safe-area-inset-bottom);\n        padding-left: env(safe-area-inset-left);\n        padding-right: env(safe-area-inset-right);\n      }\n      .app-main {\n        flex: 1;\n        display: flex;\n        flex-direction: column;\n        min-width: 0;\n        overflow: hidden;\n        position: relative;\n        z-index: 1;\n      }\n      .sidebar {\n        width: var(--dp-sidebar-width);\n        flex-shrink: 0;\n        display: flex;\n        flex-direction: column;\n        background: var(--dp-bg-1);\n        border-right: 1px solid var(--dp-border-0);\n        overflow: hidden;\n        position: relative;\n        z-index: 10;\n      }\n      @media (max-width: 768px) {\n        .sidebar {\n          position: fixed;\n          inset-y: 0;\n          left: 0;\n          z-index: 50;\n          transform: translateX(-100%);\n          box-shadow: 4px 0 40px rgba(0, 0, 0, 0.5);\n        }\n        .sidebar--mobile-open {\n          transform: translateX(0);\n        }\n      }\n      .sidebar-logo {\n        display: flex;\n        align-items: center;\n        gap: 10px;\n        padding: 16px 16px 12px;\n        border-bottom: 1px solid var(--dp-border-1);\n        flex-shrink: 0;\n      }\n      .sidebar-logo-icon {\n        width: 32px;\n        height: 32px;\n        border-radius: var(--dp-r-md);\n        background: linear-gradient(135deg, var(--dp-blue), #6e40c9);\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        color: #fff;\n        flex-shrink: 0;\n      }\n      .sidebar-logo-title {\n        font-size: 14px;\n        font-weight: 700;\n        letter-spacing: -0.3px;\n        color: var(--dp-text-0);\n      }\n      .sidebar-logo-sub {\n        font-size: 11px;\n        color: var(--dp-text-2);\n      }\n      .sidebar-section {\n        flex-shrink: 0;\n        padding: 4px 0;\n        overflow-y: auto;\n      }\n      .sidebar-channels {\n        overflow-y: auto;\n        max-height: 40vh;\n        padding: 2px 8px;\n      }\n      .sidebar-channel {\n        display: flex;\n        align-items: center;\n        gap: 8px;\n        width: 100%;\n        padding: 8px;\n        border-radius: var(--dp-r-sm);\n        background: none;\n        border: none;\n        cursor: pointer;\n        color: var(--dp-text-1);\n        font-size: 13px;\n        text-align: left;\n        position: relative;\n        min-height: 44px;\n        box-sizing: border-box;\n      }\n      .sidebar-channel:hover {\n        background: var(--dp-bg-3);\n        color: var(--dp-text-0);\n      }\n      .sidebar-channel--active {\n        background: var(--dp-blue-muted);\n        color: var(--dp-text-0);\n      }\n      .sidebar-sec {\n        display: flex;\n        align-items: center;\n        gap: 10px;\n        width: 100%;\n        padding: 10px 12px;\n        background: none;\n        border: none;\n        cursor: pointer;\n        color: var(--dp-text-1);\n        font-size: 13px;\n        text-align: left;\n        border-radius: var(--dp-r-sm);\n        margin: 1px 8px;\n        min-height: 44px;\n        box-sizing: border-box;\n      }\n      .sidebar-sec:hover {\n        background: var(--dp-bg-3);\n      }\n      .sidebar-sec--active {\n        background: var(--dp-blue-muted);\n        color: var(--dp-text-0);\n      }\n      .sidebar-sec-label {\n        flex: 1;\n      }\n      .sidebar-sec-count {\n        font-size: 11px;\n        color: var(--dp-text-2);\n        background: var(--dp-bg-3);\n        padding: 2px 6px;\n        border-radius: 10px;\n      }\n      .loading-overlay {\n        position: fixed;\n        inset: 0;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        background: rgba(1, 4, 9, 0.6);\n        z-index: 50;\n      }\n      .spinner {\n        width: 32px;\n        height: 32px;\n        border: 2px solid var(--dp-border-0);\n        border-top-color: var(--dp-blue);\n        border-radius: 50%;\n        animation: spin 0.8s linear infinite;\n      }\n      @keyframes spin {\n        to {\n          transform: rotate(360deg);\n        }\n      }\n      .sr-only {\n        position: absolute;\n        width: 1px;\n        height: 1px;\n        padding: 0;\n        margin: -1px;\n        overflow: hidden;\n        clip: rect(0, 0, 0, 0);\n        white-space: nowrap;\n        border: 0;\n      }\n      .skip-link:focus {\n        position: absolute;\n        top: 16px;\n        left: 16px;\n        z-index: 100;\n        padding: 8px 16px;\n        background: var(--dp-blue);\n        color: #fff;\n        border-radius: var(--dp-r-sm);\n        font-size: 14px;\n        font-weight: 500;\n        text-decoration: none;\n        clip: auto;\n        width: auto;\n        height: auto;\n        overflow: visible;\n      }\n    "],"\n    ","\n    ","\n    ","\n  ",["STYLE",{},"/*! tailwindcss v4.2.1 | MIT License | https://tailwindcss.com */\n@layer properties;\n@layer theme, base, components, utilities;\n@layer theme {\n  :root, :host {\n    --font-sans: var(--font-family-sans);\n    --font-mono: var(--font-family-mono);\n    --color-red-50: oklch(97.1% 0.013 17.38);\n    --color-red-100: oklch(93.6% 0.032 17.717);\n    --color-red-300: oklch(80.8% 0.114 19.571);\n    --color-red-400: oklch(70.4% 0.191 22.216);\n    --color-red-500: oklch(63.7% 0.237 25.331);\n    --color-red-600: oklch(57.7% 0.245 27.325);\n    --color-red-800: oklch(44.4% 0.177 26.899);\n    --color-red-900: oklch(39.6% 0.141 25.7